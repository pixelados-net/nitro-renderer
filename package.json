{
  "name": "@nitrots/nitro-renderer",
  "description": "Javascript library for rendering Nitro in the browser using PixiJS",
  "version": "3.0.1",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://git.krews.org/nitro/nitro-renderer.git"
  },
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://git.krews.org/nitro/nitro-renderer/issues"
  },
  "homepage": "https://git.krews.org/nitro/nitro-renderer",
  "type": "module",
  "files": [
    "index.ts",
    "src",
    "dist"
  ],
  "exports": {
    ".": "./index.ts",
    "./standalone": "./src/standalone/index.ts",
    "./*": "./*"
  },
  "scripts": {
    "build": "vite build",
    "compile": "tsc --project ./tsconfig.json --noEmit false",
    "typecheck": "tsc --project ./tsconfig.json",
    "lint": "eslint ./src",
    "eslint": "eslint ./src --fix",
    "test": "vitest run"
  },
  "main": "./index",
  "dependencies": {
    "@pixi/tilemap": "5.0.2",
    "gifenc": "^1.0.3",
    "gifuct-js": "^2.1.2",
    "howler": "^2.2.4",
    "pako": "^2.1.0",
    "pixi-filters": "6.1.5",
    "pixi.js": "8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/howler": "^2.2.7",
    "@types/pako": "^2.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^29.1.1",
    "tslib": "^2.8.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
